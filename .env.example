# Sao chép thành .env (không commit). Hoặc dùng chung Frontend/.env — load-env.ts vẫn đọc được.

# --- Bắt buộc cho API login / Bearer token ---
# Nếu thiếu, code dùng fallback dev (không nên production).
# Dev: có thể trùng giá trị AUTH_SECRET / NEXTAUTH_SECRET ở Frontend cho đỡ lệch.
JWT_SECRET=thay-bang-chuoi-du-manh-toi-thieu-32-ky-tu

# Một dòng là đủ. Supabase pooler (:6543) có thể làm `npm run db:migrate:deploy` treo — khi đó mở
# Supabase → SQL Editor, dán nội dung file prisma/sql/add_user_profile_columns_supabase.sql rồi Run.
DATABASE_URL=postgresql://USER:PASS@HOST:5432/postgres?schema=public

BACKEND_PORT=3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Giữ chỗ checkout (POST /api/reservations/checkout-hold) dùng Redis hoặc bộ nhớ trong process.
# - Production: đặt UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN (Upstash REST API).
# - Dev khi DNS/mạng lỗi hoặc chưa có Upstash: USE_MEMORY_REDIS=1 (cùng process, không dùng production).
USE_MEMORY_REDIS=1
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
